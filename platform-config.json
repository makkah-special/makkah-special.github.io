(function(){
  'use strict';
  if (window.__MK_COMMON_UI__) return;
  window.__MK_COMMON_UI__ = true;
  const pages = [
    ['الرئيسية','index.html','🏠'],
    ['يسير','Slowlearning.html','🧩'],
    ['الدمج الفكري','Intellectualdisability.html','📘'],
    ['ملف الطالب','students.html','👨‍👩‍👧'],
    ['ملف الدمج','dumaj-students.html','🧠'],
    ['بوابة المعلمين','teachers-portal.html','👨‍🏫'],
    ['روابط الإنجاز','teacher-portfolio-links.html','📁'],
    ['لوحة التحكم','unified-admin.html','📊'],
    ['تواصل','contact.html','☎️']
  ];
  const current = (location.pathname.split('/').pop() || 'index.html').toLowerCase();
  function createNav(){
    if (document.querySelector('.mk-unified-nav')) return;
    const nav = document.createElement('nav');
    nav.className = 'mk-unified-nav';
    nav.setAttribute('aria-label','التنقل الرئيسي الموحد');
    const links = pages.map(([label,href,icon])=>{
      const isActive = current === href.toLowerCase();
      return `<a href="${href}" class="${isActive?'mk-active':''}" ${isActive?'aria-current="page"':''}><span>${icon}</span><span>${label}</span></a>`;
    }).join('');
    nav.innerHTML = `
      <div class="mk-nav-inner">
        <a class="mk-nav-brand" href="index.html" aria-label="العودة للرئيسية">
          <img src="school-logo.png" alt="شعار المدرسة" onerror="this.style.display='none'">
          <span>قسم ذوي الإعاقة<small>مدرسة مكة المكرمة المتوسطة</small></span>
        </a>
        <button class="mk-mobile-toggle" type="button" aria-expanded="false">☰ القائمة</button>
        <div class="mk-nav-links">${links}</div>
      </div>`;
    const topbar = document.querySelector('.topbar');
    if (topbar && topbar.parentNode) topbar.parentNode.insertBefore(nav, topbar.nextSibling);
    else document.body.insertBefore(nav, document.body.firstChild);
    const btn = nav.querySelector('.mk-mobile-toggle');
    btn && btn.addEventListener('click',()=>{
      const open = nav.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
  }
  function createBackTop(){
    if (document.querySelector('.mk-backtop')) return;
    const btn = document.createElement('button');
    btn.className='mk-backtop'; btn.type='button'; btn.title='العودة للأعلى'; btn.textContent='↑';
    document.body.appendChild(btn);
    btn.addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));
    const toggle=()=>btn.classList.toggle('show', window.scrollY>450);
    window.addEventListener('scroll',toggle,{passive:true}); toggle();
  }
  function createQuickFiles(){
    if (document.querySelector('.mk-quick-files')) return;
    const box = document.createElement('div');
    box.className='mk-quick-files';
    box.innerHTML = `<a href="students.html">ملف طالب يسير</a><a href="dumaj-students.html">ملف طالب الدمج</a><a href="teacher-portfolio-links.html">روابط إنجاز المعلمين</a><a href="unified-admin.html">لوحة التحكم</a>`;
    document.body.appendChild(box);
  }
  function markExternal(){
    document.querySelectorAll('a[href]').forEach(a=>{
      if(a.hostname && a.hostname !== location.hostname){a.setAttribute('target','_blank');a.setAttribute('rel','noopener');}
    });
  }
  document.addEventListener('DOMContentLoaded',()=>{createNav();createBackTop();createQuickFiles();markExternal();});
})();
